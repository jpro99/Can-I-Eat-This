# Database (SQLite for local dev; use PostgreSQL URL in production)
DATABASE_URL="file:./dev.db"

# OpenAI — powers label OCR parsing, plate photo AI, and voice meal parsing
OPENAI_API_KEY="sk-your-key-here"

# Optional: override OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# App URL for PWA manifest (production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
