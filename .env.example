# Database — use Neon/Supabase/Vercel Postgres in production (required on Vercel)
# Local dev: create a free database at https://neon.tech and paste the connection string here
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# OpenAI — powers label OCR parsing, plate photo AI, and voice meal parsing
OPENAI_API_KEY="sk-your-key-here"

# Optional: override OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# App URL for PWA manifest (production — your Vercel URL)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
